generator client {
  provider      = "prisma-client-js"
  // "native" = local dev (macOS / glibc Linux), "linux-musl-openssl-3.0.x" = the
  // Alpine-based Docker runner image. Without this Prisma's autodetection falls
  // back to the openssl-1.1 engine, which Alpine 3.20+ can no longer load.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String       @id @default(cuid())
  ip_fingerprint String?      @unique
  telegram_id    BigInt?      @unique
  username       String?
  is_premium     Boolean      @default(false)
  created_at     DateTime     @default(now())

  likes          Like[]
  saves          Save[]
  watch_events   WatchEvent[]
  comments       Comment[]

  @@index([ip_fingerprint])
  @@index([telegram_id])
  @@map("users")
}

model Video {
  id                String   @id @default(cuid())
  url               String   // public URL path e.g. /videos/filename.mp4
  thumbnail         String
  title             String
  file_path         String   @default("") // absolute path on the VPS
  file_size         BigInt   @default(0)
  original_filename String   @default("")
  duration          Int      @default(0)
  views             Int      @default(0)
  created_at        DateTime @default(now())

  likes        Like[]
  saves        Save[]
  watch_events WatchEvent[]
  comments     Comment[]

  @@index([created_at])
  @@index([views])
  @@map("videos")
}

model Comment {
  id         String   @id @default(cuid())
  video_id   String
  user_id    String
  body       String   @db.VarChar(500)
  created_at DateTime @default(now())

  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([video_id])
  @@index([created_at])
  @@map("comments")
}

model Like {
  user_id  String
  video_id String

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@id([user_id, video_id])
  @@map("likes")
}

model Save {
  user_id  String
  video_id String

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@id([user_id, video_id])
  @@map("saves")
}

model WatchEvent {
  id         String   @id @default(cuid())
  user_id    String
  video_id   String
  watch_time Int      @default(0)
  completed  Boolean  @default(false)
  created_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([video_id])
  @@map("watch_events")
}
