# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/nfws_db?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Google Cloud Storage ────────────────────────────────────────────────────
GCP_BUCKET="your-gcs-bucket-name"
GCP_PROJECT_ID="your-gcp-project-id"
GCP_KEY_FILE="secrets/gcp-service-account.json"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Redgifs Auth ────────────────────────────────────────────────────────────
REDGIFS_USERNAME="your_redgifs_username"
REDGIFS_PASSWORD="your_redgifs_password"

# ─── Redgifs Pipeline ────────────────────────────────────────────────────────
# Comma-separated search tags to fetch from Redgifs
REDGIFS_SEARCH_TAGS="nsfw,amateur"
# Max videos per tag per run
PIPELINE_LIMIT="25"
# Cron schedule (default: every 6 hours)
PIPELINE_CRON="0 */6 * * *"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
LOG_LEVEL="debug"
