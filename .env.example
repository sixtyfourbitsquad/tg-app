# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/nfws_db?schema=public"

# ─── Redis ──────────────────────────────────────────────────────────────────
# ioredis connection string
REDIS_URL="redis://localhost:6379"

# ─── Google Cloud Storage ───────────────────────────────────────────────────
GCP_BUCKET="your-gcs-bucket-name"
GCP_PROJECT_ID="your-gcp-project-id"
# Path to service account JSON key file (relative to project root)
GCP_KEY_FILE="secrets/gcp-service-account.json"

# ─── Reddit API ─────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID="your-reddit-app-client-id"
REDDIT_SECRET="your-reddit-app-secret"
REDDIT_USER_AGENT="nfws-bot/1.0 by u/your-username"

# ─── NextAuth ───────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Pipeline ───────────────────────────────────────────────────────────────
# Subreddits to scrape, comma-separated
PIPELINE_SUBREDDITS="nsfw,realgirls,amateur"
# Max posts per subreddit per run
PIPELINE_LIMIT="25"
# Cron schedule (default: every 6 hours)
PIPELINE_CRON="0 */6 * * *"

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
LOG_LEVEL="debug"
